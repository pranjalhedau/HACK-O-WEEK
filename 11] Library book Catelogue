<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Library Catalogue</title>

<style>
body {
    font-family: Arial;
    margin: 0;
    background: #f4f6f9;
}

/* Header */
.header {
    background: linear-gradient(270deg, #1e3c72, #2a5298, #6a11cb);
    color: white;
    text-align: center;
    padding: 25px;
}

/* Navbar */
.navbar {
    display: flex;
    justify-content: center;
    gap: 20px;
}

.navbar a {
    cursor: pointer;
    font-weight: bold;
}

/* Sections */
.section { display: none; padding: 20px; }
.active { display: block; }

/* Controls */
.controls input, .controls select {
    padding: 8px;
    margin: 5px;
    border-radius: 20px;
    border: none;
}

/* Books */
.container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
    gap: 20px;
}

.book {
    background: white;
    padding: 10px;
    border-radius: 10px;
    cursor: pointer;
    position: relative;
    transition: 0.3s;
}

.book:hover { transform: scale(1.05); }

.book img { width: 100%; border-radius: 10px; }

/* ❤️ */
.fav {
    position: absolute;
    top: 10px;
    right: 10px;
}

/* Modal */
#modal {
    display: none;
    position: fixed;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
}

.modal-box {
    background: white;
    width: 300px;
    margin: 10% auto;
    padding: 20px;
    text-align: center;
}

/* Footer */
footer {
    text-align: center;
    padding: 10px;
    background: #2c3e50;
    color: white;
}
</style>
</head>

<body>

<div class="header">
<h1>📚 Library Catalogue</h1>

<div class="navbar">
<a onclick="showSection('home')">Home</a>
<a onclick="showSection('category')">Categories</a>
