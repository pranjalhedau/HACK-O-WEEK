<!DOCTYPE html>
<html>
<head>
<title>Smart Quiz App</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI;
}

body{
background:linear-gradient(135deg,#1e3a8a,#111827,#4c1d95);
color:white;
height:100vh;
}

/* MAIN LAYOUT */

.main{
display:flex;
height:100vh;
}

/* SIDE PANEL */

.side-panel{
width:20%;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(10px);
padding:20px;
}

.side-panel h3{
text-align:center;
margin-bottom:20px;
}

.q-numbers{
display:flex;
flex-wrap:wrap;
gap:10px;
justify-content:center;
}

.q-numbers button{
width:40px;
height:40px;
border:none;
border-radius:50%;
background:#374151;
color:white;
cursor:pointer;
transition:0.3s;
}

.q-numbers button:hover{
transform:scale(1.1);
}

.q-numbers button.active{
background:#3b82f6;
}

.q-numbers button.answered{
background:#10b981;
}

/* QUIZ AREA */

.quiz-area{
width:80%;
padding:40px;
position:relative;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(10px);
}

/* TIMER */

.timer{
position:absolute;
right:40px;
top:20px;
background:#ef4444;
padding:8px 15px;
border-radius:20px;
}

/* PROGRESS BAR */

.progress-bar{
height:8px;
background:#374151;
border-radius:10px;
margin-bottom:30px;
overflow:hidden;
}

.progress{
height:100%;
width:0%;
background:#3b82f6;
transition:0.3s;
}

/* QUESTIONS */

.question{
display:none;
animation:fade 0.5s ease;
}

.question.active{
display:block;
}

@keyframes fade{
from{opacity:0; transform:translateY(20px);}
to{opacity:1; transform:translateY(0);}
}

/* OPTIONS */

.option{
margin:15px 0;
}

.option label{
display:block;
padding:12px;
background:#1f2937;
border-radius:8px;
cursor:pointer;
transition:0.3s;
}

.option label:hover{
background:#3b82f6;
transform:scale(1.03);
}

/* BUTTONS */

.navigation{
margin-top:30px;
}

button{
padding:8px 15px;
border:none;
border-radius:6px;
cursor:pointer;
margin-right:10px;
}

.prev{background:#6b7280;color:white;}
.next{background:#3b82f6;color:white;}
.submit{background:#10b981;color:white;}

/* RESULT */

#result{
display:none;
text-align:center;
margin-top:80px;
}

#result h1{
font-size:50px;
color:#10b981;
animation:pop 0.6s ease;
}

@keyframes pop{
from{transform:scale(0);}
to{transform:scale(1);}
}

/* POPUP */

.popup{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.7);
display:flex;
justify-content:center;
align-items:center;
visibility:hidden;
opacity:0;
transition:0.3s;
}

.popup.active{
visibility:visible;
opacity:1;
}

.popup-box{
background:white;
color:black;
padding:30px;
border-radius:10px;
text-align:center;
}

/* BALLOON CELEBRATION */

.balloon{
position:fixed;
bottom:-100px;
width:50px;
height:65px;
border-radius:50% 50% 45% 45%;
animation:floatUp 6s linear forwards;
cursor:pointer;
}

.balloon:after{
content:"";
position:absolute;
width:2px;
height:40px;
background:white;
left:50%;
top:65px;
}

@keyframes floatUp{
0%{
transform:translateY(0);
opacity:1;
}
100%{
transform:translateY(-120vh);
opacity:0;
}
}

</style>

</head>

<body>

<div class="main">

<div class="side-panel">
<h3>Questions</h3>
<div class="q-numbers" id="questionNumbers"></div>
</div>

<div class="quiz-area">

<div class="timer">Time Left: <span id="time">120</span>s</div>

<div class="progress-bar">
<div class="progress" id="progress"></div>
</div>

<form id="quizForm">

<!-- QUESTION 1 -->
<div class="question active">
<h2>1. What does CPU stand for?</h2>

<div class="option">
<label><input type="radio" name="q1" value="1"> Central Processing Unit</label>
</div>

<div class="option">
<label><input type="radio" name="q1" value="0"> Computer Personal Unit</label>
</div>

<div class="option">
<label><input type="radio" name="q1" value="0"> Central Print Unit</label>
</div>

<div class="option">
<label><input type="radio" name="q1" value="0"> Control Processing Unit</label>
</div>

</div>

<!-- QUESTION 2 -->
<div class="question">
<h2>2. Which data structure uses FIFO?</h2>

<div class="option">
<label><input type="radio" name="q2" value="0"> Stack</label>
</div>

<div class="option">
<label><input type="radio" name="q2" value="1"> Queue</label>
</div>

<div class="option">
<label><input type="radio" name="q2" value="0"> Tree</label>
</div>

<div class="option">
<label><input type="radio" name="q2" value="0"> Graph</label>
</div>

</div>

<!-- QUESTION 3 -->
<div class="question">
<h2>3. HTML stands for?</h2>

<div class="option">
<label><input type="radio" name="q3" value="1"> Hyper Text Markup Language</label>
</div>

<div class="option">
<label><input type="radio" name="q3" value="0"> High Text Machine Language</label>
</div>

<div class="option">
<label><input type="radio" name="q3" value="0"> Hyperlink Mark Language</label>
</div>

<div class="option">
<label><input type="radio" name="q3" value="0"> None</label>
</div>

</div>

<!-- QUESTION 4 -->
<div class="question">
<h2>4. Binary of decimal 2?</h2>

<div class="option">
<label><input type="radio" name="q4" value="1"> 10</label>
</div>

<div class="option">
<label><input type="radio" name="q4" value="0"> 01</label>
</div>

<div class="option">
<label><input type="radio" name="q4" value="0"> 11</label>
</div>

<div class="option">
<label><input type="radio" name="q4" value="0"> 00</label>
</div>

</div>

<!-- QUESTION 5 -->
<div class="question">
<h2>5. Which is an Operating System?</h2>

<div class="option">
<label><input type="radio" name="q5" value="1"> Windows</label>
</div>

<div class="option">
<label><input type="radio" name="q5" value="0"> Chrome</label>
</div>

<div class="option">
<label><input type="radio" name="q5" value="0"> MS Word</label>
</div>

<div class="option">
<label><input type="radio" name="q5" value="0"> Google</label>
</div>

</div>

<div class="navigation">
<button type="button" class="prev" onclick="prevQ()">Previous</button>
<button type="button" class="next" onclick="nextQ()">Next</button>
<button type="button" class="submit" onclick="openPopup()">Submit</button>
</div>

</form>

<div id="result">
<h2>Quiz Completed 🎉</h2>
<h1 id="score"></h1>
</div>

</div>
</div>

<div class="popup" id="popup">
<div class="popup-box">
<h3>Submit Quiz?</h3>
<br>
<button onclick="submitQuiz()" class="submit">Yes</button>
<button onclick="closePopup()" class="prev">Cancel</button>
</div>
</div>

<audio id="popSound" src="https://assets.mixkit.co/active_storage/sfx/1109/1109-preview.mp3"></audio>

<script>

let current=0
const questions=document.querySelectorAll(".question")
const progress=document.getElementById("progress")
const qNumbers=document.getElementById("questionNumbers")

questions.forEach((q,i)=>{
let btn=document.createElement("button")
btn.innerText=i+1
btn.onclick=()=>showQ(i)
qNumbers.appendChild(btn)
})

function showQ(index){
questions.forEach(q=>q.classList.remove("active"))
current=index
questions[current].classList.add("active")
progress.style.width=((current+1)/questions.length)*100+"%"
}

function nextQ(){
if(current<questions.length-1) showQ(current+1)
}

function prevQ(){
if(current>0) showQ(current-1)
}

document.querySelectorAll("input").forEach(input=>{
input.addEventListener("change",()=>{
let qIndex=parseInt(input.name.replace("q",""))-1
qNumbers.children[qIndex].classList.add("answered")
})
})

/* TIMER */

let timeLeft=120
const timer=document.getElementById("time")

let countdown=setInterval(()=>{
timeLeft--
timer.innerText=timeLeft
if(timeLeft<=0){
clearInterval(countdown)
submitQuiz()
}
},1000)

/* POPUP */

function openPopup(){
document.getElementById("popup").classList.add("active")
}

function closePopup(){
document.getElementById("popup").classList.remove("active")
}

/* BALLOON CELEBRATION */

function confetti(){

let colors=["#ff4d4d","#4dff88","#4db8ff","#ffd24d","#ff66cc","#66ffff"]

for(let i=0;i<25;i++){

let balloon=document.createElement("div")
balloon.className="balloon"

balloon.style.left=Math.random()*100+"%"
balloon.style.background=colors[Math.floor(Math.random()*colors.length)]
balloon.style.animationDuration=(4+Math.random()*3)+"s"

balloon.onclick=function(){
document.getElementById("popSound").play()
balloon.remove()
}

document.body.appendChild(balloon)

setTimeout(()=>{
balloon.remove()
},7000)

}

}

/* SUBMIT */

function submitQuiz(){

clearInterval(countdown)

let score=0

for(let i=1;i<=5;i++){
let ans=document.forms["quizForm"]["q"+i].value
if(ans==1) score++
}

document.getElementById("popup").classList.remove("active")
document.getElementById("quizForm").style.display="none"
document.getElementById("result").style.display="block"

document.getElementById("score").innerText="Your Score: "+score+" / 5"

confetti()

}

</script>

</body>
</html>
